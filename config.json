{
  "launch_options": {
    "executablePath": "/usr/bin/chromium",
    "args": ["--no-sandbox", "--disable-setuid-sandbox"]
  },
  "pdf_options": {
    "format": "A4",
    "margin": {
      "top": "20mm",
      "right": "20mm",
      "bottom": "20mm",
      "left": "20mm"
    },
    "printBackground": true,
    "displayHeaderFooter": false
  },
  "stylesheet": ["style.css"]
}
